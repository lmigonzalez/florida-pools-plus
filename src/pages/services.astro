---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import newPoolImg from "../assets/gallery/im-2.jpg";
import renovationImg from "../assets/gallery/im-34.jpg";
import maintenanceImg from "../assets/gallery/im-38.jpg";
import salesImg from "../assets/gallery/im-46.jpg";
import contractorsImg from "../assets/gallery/im-52.jpg";
import CustomLink from "../components/custom-link.astro";
import heroImage from "../assets/hero/hero-1.jpg";
---

<Layout>
  <!-- Hero Section (compact) -->
  <section
    class="relative w-full min-h-[350px] md:min-h-[400px] py-12 md:py-16 flex items-center justify-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <img
        src={heroImage.src}
        alt="Professional pool services"
        class="w-full h-full object-cover bg-fixed"
      />
      <div class="absolute inset-0 bg-gray-900/60" />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-5 text-center text-white">
      <h1
        class="text-3xl md:text-4xl font-bold mb-3 leading-tight"
        data-aos="fade-up"
        data-aos-duration="600"
      >
        Our Pool Services
      </h1>
      <p
        class="text-base md:text-lg text-gray-200 mb-6"
        data-aos="fade-up"
        data-aos-delay="150"
        data-aos-duration="600"
      >
        Design, construction, maintenance, and more — all across Miami.
      </p>
      <div
        class="flex justify-center"
        data-aos="fade-up"
        data-aos-delay="250"
        data-aos-duration="600"
      >
        <CustomLink href="/contact" children="Get a Free Quote" />
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="w-full py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div
        class="text-center mb-12"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Comprehensive Pool Services
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Explore our wide range of services designed to meet all your pool
          needs, from initial design to ongoing maintenance.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <!-- Service 1: New Pool Construction -->
        <div
          class="bg-white border border-gray-200 overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:border-blue-400"
          data-aos="fade-up"
          data-aos-duration="1000"
        >
          <Image
            src={newPoolImg}
            alt="New Pool Construction"
            class="w-full h-64 object-cover"
            width={800}
            height={512}
            quality={100}
          />
          <div class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              New Pool Construction
            </h2>
            <p class="text-gray-700 leading-relaxed mb-4">
              We design and build custom pools that match your style, space, and
              budget. From modern designs to traditional layouts, we handle the
              entire construction process from start to finish.
            </p>
            <div class="space-y-2 mb-6">
              <h3 class="font-semibold text-gray-800">What We Offer:</h3>
              <ul class="list-disc list-inside text-gray-700 space-y-1 ml-2">
                <li>Custom pool design and planning</li>
                <li>Excavation and construction</li>
                <li>Plumbing and electrical installation</li>
                <li>Decking and landscaping integration</li>
                <li>Equipment installation and setup</li>
                <li>Final inspection and handover</li>
              </ul>
            </div>
            <p class="text-gray-600 italic">
              Transform your backyard into a stunning oasis with a pool designed
              specifically for your lifestyle.
            </p>
          </div>
        </div>

        <!-- Service 2: Renovations -->
        <div
          class="bg-white border border-gray-200 overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:border-blue-400"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
        >
          <Image
            src={renovationImg}
            alt="Complete Pool & Deck Renovations"
            class="w-full h-64 object-cover"
            width={800}
            height={512}
            quality={100}
          />
          <div class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              Complete Pool & Deck Renovations
            </h2>
            <p class="text-gray-700 leading-relaxed mb-4">
              Transform old or damaged pools into stunning new outdoor spaces.
              Resurfacing, tile replacement, decking, lighting, equipment
              upgrades — we do it all.
            </p>
            <div class="space-y-2 mb-6">
              <h3 class="font-semibold text-gray-800">Renovation Services:</h3>
              <ul class="list-disc list-inside text-gray-700 space-y-1 ml-2">
                <li>Pool resurfacing and replastering</li>
                <li>Tile and coping replacement</li>
                <li>Deck restoration and resurfacing</li>
                <li>LED lighting upgrades</li>
                <li>Equipment modernization</li>
                <li>Water feature installation</li>
                <li>Safety feature additions</li>
              </ul>
            </div>
            <p class="text-gray-600 italic">
              Breathe new life into your existing pool with our comprehensive
              renovation services.
            </p>
          </div>
        </div>

        <!-- Service 3: Maintenance -->
        <div
          class="bg-white border border-gray-200 overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:border-blue-400"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <Image
            src={maintenanceImg}
            alt="Weekly Pool Maintenance"
            class="w-full h-64 object-cover"
            width={800}
            height={512}
            quality={100}
          />
          <div class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              Weekly Pool Maintenance
            </h2>
            <p class="text-gray-700 leading-relaxed mb-4">
              Keep your water clear, clean, and safe. Our maintenance team
              handles chemicals, cleaning, equipment checks, and weekly service
              visits.
            </p>
            <div class="space-y-2 mb-6">
              <h3 class="font-semibold text-gray-800">Maintenance Includes:</h3>
              <ul class="list-disc list-inside text-gray-700 space-y-1 ml-2">
                <li>Weekly water testing and chemical balancing</li>
                <li>Skimmer and filter cleaning</li>
                <li>Pool surface and tile brushing</li>
                <li>Equipment inspection and maintenance</li>
                <li>Vacuuming and debris removal</li>
                <li>Seasonal opening and closing services</li>
                <li>Emergency repair response</li>
              </ul>
            </div>
            <p class="text-gray-600 italic">
              Enjoy your pool worry-free while we handle all the maintenance
              details.
            </p>
          </div>
        </div>

        <!-- Service 4: Equipment Sales -->
        <div
          class="bg-white border border-gray-200 overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:border-blue-400"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
        >
          <Image
            src={salesImg}
            alt="Pool Equipment Sales"
            class="w-full h-64 object-cover"
            width={800}
            height={512}
            quality={100}
          />
          <div class="p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              Pool Equipment Sales
            </h2>
            <p class="text-gray-700 leading-relaxed mb-4">
              We offer pumps, filters, heaters, lights, automation systems, and
              more — everything you need to keep your pool running efficiently.
            </p>
            <div class="space-y-2 mb-6">
              <h3 class="font-semibold text-gray-800">Available Equipment:</h3>
              <ul class="list-disc list-inside text-gray-700 space-y-1 ml-2">
                <li>Energy-efficient pool pumps</li>
                <li>Advanced filtration systems</li>
                <li>Pool heaters and heat pumps</li>
                <li>LED pool lighting systems</li>
                <li>Automation and control systems</li>
                <li>Cleaning equipment and robots</li>
                <li>Safety covers and alarms</li>
                <li>Water treatment systems</li>
              </ul>
            </div>
            <p class="text-gray-600 italic">
              Upgrade your pool with the latest technology and energy-efficient
              equipment.
            </p>
          </div>
        </div>

        <!-- Service 5: Contractors -->
        <div
          class="bg-white border border-gray-200 overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:border-blue-400 md:col-span-2"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="400"
        >
          <div class="flex flex-col md:flex-row">
            <Image
              src={contractorsImg}
              alt="Residential & Commercial Contractors"
              class="w-full md:w-1/2 h-64 md:h-auto object-cover"
              width={800}
              height={512}
              quality={100}
            />
            <div class="p-8 flex-1">
              <h2 class="text-2xl font-bold text-gray-900 mb-4">
                Residential & Commercial Contractors
              </h2>
              <p class="text-gray-700 leading-relaxed mb-4">
                We work with homes, hotels, apartments, HOAs, and commercial
                buildings throughout Miami. No project is too big or too small.
              </p>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                  <h3 class="font-semibold text-gray-800 mb-2">
                    Residential Services:
                  </h3>
                  <ul
                    class="list-disc list-inside text-gray-700 space-y-1 ml-2"
                  >
                    <li>Single-family home pools</li>
                    <li>Custom backyard designs</li>
                    <li>Luxury pool features</li>
                    <li>Homeowner association projects</li>
                  </ul>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-800 mb-2">
                    Commercial Services:
                  </h3>
                  <ul
                    class="list-disc list-inside text-gray-700 space-y-1 ml-2"
                  >
                    <li>Hotel and resort pools</li>
                    <li>Apartment complex pools</li>
                    <li>Fitness center pools</li>
                    <li>Community recreation centers</li>
                    <li>Commercial maintenance contracts</li>
                  </ul>
                </div>
              </div>
              <p class="text-gray-600 italic">
                Trusted contractors for both residential and commercial pool
                projects across Miami-Dade County.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="w-full py-16 md:py-24 bg-gray-100">
    <div class="max-w-6xl mx-auto px-5">
      <div
        class="text-center mb-12"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Why Choose Our Services
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          We bring years of experience, quality craftsmanship, and exceptional
          customer service to every project.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div
          class="bg-white p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
        >
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Licensed & Insured
          </h3>
          <p class="text-gray-700">
            Fully licensed contractors with comprehensive insurance coverage for
            your peace of mind.
          </p>
        </div>
        <div
          class="bg-white p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Quality Guarantee
          </h3>
          <p class="text-gray-700">
            We stand behind our work with comprehensive warranties and ongoing
            support.
          </p>
        </div>
        <div
          class="bg-white p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
        >
          <h3 class="text-xl font-bold text-gray-900 mb-3">Local Expertise</h3>
          <p class="text-gray-700">
            Deep knowledge of Miami's climate, building codes, and local pool
            requirements.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="w-full py-16 md:py-20 bg-blue-700 text-white">
    <div
      class="max-w-4xl mx-auto px-5 text-center"
      data-aos="fade-up"
      data-aos-duration="1000"
    >
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Ready to Transform Your Outdoors?
      </h2>
      <p class="text-xl text-blue-100 mb-8 leading-relaxed">
        Contact us today for a free consultation and quote. Let's bring your
        pool vision to life.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-stretch sm:items-center">
        <CustomLink href="/contact" children="Get a Free Quote" />
        <a
          href="tel:+1234567890"
          class="group bg-transparent border-2 border-white hover:bg-white text-sm sm:text-md flex w-full sm:w-fit items-center justify-center gap-2 overflow-hidden px-6 py-3 text-white hover:text-blue-700 shadow hover:shadow-2xl transition-all duration-300 ease-out font-medium rounded"
        >
          Call Us Now
        </a>
      </div>
    </div>
  </section>
</Layout>
