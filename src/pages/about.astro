---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import aboutImage from "../assets/gallery/im-12.jpg";
import CustomLink from "../components/custom-link.astro";
import heroImage from "../assets/hero/hero-2.jpg";
---

<Layout>
  <!-- Hero Section (compact) -->
  <section
    class="relative w-full min-h-[350px] md:min-h-[400px] py-12 md:py-16 flex items-center justify-center overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <img
        src={heroImage.src}
        alt="About Florida Pools Plus"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gray-900/60" />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto px-5 text-center text-white">
      <h1
        class="text-3xl md:text-4xl font-bold mb-3 leading-tight"
        data-aos="fade-up"
        data-aos-duration="600"
      >
        About Florida Pools Plus
      </h1>
      <p
        class="text-base md:text-lg text-gray-200 mb-6"
        data-aos="fade-up"
        data-aos-delay="150"
        data-aos-duration="600"
      >
        Family-owned and operated, serving South Florida with exceptional pool
        services for over 15 years.
      </p>
      <div
        class="flex justify-center"
        data-aos="fade-up"
        data-aos-delay="250"
        data-aos-duration="600"
      >
        <CustomLink href="/contact" children="Get a Free Quote" />
      </div>
    </div>
  </section>

  <!-- Our Story Section -->
  <section class="w-full py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center mb-20">
        <!-- Image -->
        <div
          class="relative order-2 md:order-1"
          data-aos="fade-right"
          data-aos-duration="1000"
        >
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <Image
              src={aboutImage}
              alt="Florida Pools Plus team and construction"
              class="w-full h-auto object-cover"
              width={800}
              height={600}
              quality={100}
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-blue-900/20 to-transparent"
            >
            </div>
          </div>
          <div
            class="absolute -bottom-6 -right-6 w-32 h-32 bg-blue-100 rounded-full opacity-50 -z-10 hidden md:block"
          >
          </div>
        </div>

        <!-- Content -->
        <div
          class="order-1 md:order-2"
          data-aos="fade-left"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <div
            class="inline-block bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6"
          >
            Our Story
          </div>
          <h2
            class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight"
          >
            Trusted Pool Experts Serving Miami for Over 15 Years
          </h2>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            Florida Pools Plus was founded in 2009 as a family-owned business
            with a simple mission: to provide exceptional pool construction,
            renovation, and maintenance services to homeowners and businesses
            throughout Miami-Dade County.
          </p>
          <p class="text-lg text-gray-700 mb-6 leading-relaxed">
            What started as a small local operation has grown into one of
            Miami's most trusted pool service companies. We've built hundreds of
            custom pools, transformed countless outdated pools through
            renovation, and maintained thousands of pools to crystal-clear
            perfection.
          </p>
          <p class="text-lg text-gray-700 leading-relaxed">
            Our commitment to quality craftsmanship, honest pricing, and
            outstanding customer service has earned us a reputation for
            excellence. We're not just contractors—we're your neighbors, and we
            treat every project as if it were our own.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do Section -->
  <section class="w-full py-16 md:py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-5">
      <div
        class="text-center mb-12"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          What We Do
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Florida Pools Plus specializes in building and maintaining
          high-quality pools for residential and commercial properties. Whether
          you're looking to build a brand-new pool, completely renovate an old
          one, or keep your water crystal clear year-round, our team delivers
          exceptional results with fast, reliable service.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div
          class="bg-white p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
        >
          <div
            class="w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            New Pool Construction
          </h3>
          <p class="text-gray-700">
            Custom-designed pools built to match your vision, space, and budget.
            From modern infinity pools to traditional family pools, we handle
            every aspect of construction.
          </p>
        </div>

        <div
          class="bg-white p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <div
            class="w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Pool Renovations</h3>
          <p class="text-gray-700">
            Complete pool and deck transformations. Resurfacing, tile
            replacement, equipment upgrades, and modern lighting to bring your
            pool back to life.
          </p>
        </div>

        <div
          class="bg-white p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
        >
          <div
            class="w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Weekly Maintenance
          </h3>
          <p class="text-gray-700">
            Professional pool maintenance services to keep your water clean,
            safe, and ready to enjoy. Weekly visits, chemical balancing, and
            equipment care.
          </p>
        </div>

        <div
          class="bg-white p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="400"
        >
          <div
            class="w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Equipment Sales</h3>
          <p class="text-gray-700">
            Top-quality pool equipment from leading manufacturers. Pumps,
            filters, heaters, automation systems, and more to keep your pool
            running efficiently.
          </p>
        </div>

        <div
          class="bg-white p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="500"
        >
          <div
            class="w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Commercial Services
          </h3>
          <p class="text-gray-700">
            Specialized services for hotels, apartments, HOAs, and commercial
            properties. Large-scale projects and maintenance contracts
            throughout Miami.
          </p>
        </div>

        <div
          class="bg-white p-8 rounded-xl shadow-lg border border-gray-200 hover:shadow-xl transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="600"
        >
          <div
            class="w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">
            Emergency Repairs
          </h3>
          <p class="text-gray-700">
            Fast response times for urgent pool issues. Equipment failures,
            leaks, and other emergencies handled quickly and professionally.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Values Section -->
  <section class="w-full py-16 md:py-24 bg-white">
    <div class="max-w-6xl mx-auto px-5">
      <div
        class="text-center mb-12"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Our Core Values
        </h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          These principles guide everything we do and ensure you receive the
          best possible service.
        </p>
      </div>

      <div class="space-y-8">
        <div
          class="flex items-start gap-6 group bg-gray-50 p-6 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
        >
          <div
            class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center group-hover:bg-sky-600 transition-colors"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">
              Family-Owned Miami Business
            </h3>
            <p class="text-gray-700 text-lg">
              Locally owned and operated since 2009, we're your neighbors who
              understand Miami's unique pool needs. We're not a faceless
              corporation—we're a family business that cares about our
              community.
            </p>
          </div>
        </div>

        <div
          class="flex items-start gap-6 group bg-gray-50 p-6 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <div
            class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center group-hover:bg-sky-600 transition-colors"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">
              Licensed & Insured Contractors
            </h3>
            <p class="text-gray-700 text-lg">
              Fully licensed, bonded, and insured for your protection. We
              maintain all required certifications and insurance coverage,
              giving you complete peace of mind on every project.
            </p>
          </div>
        </div>

        <div
          class="flex items-start gap-6 group bg-gray-50 p-6 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
        >
          <div
            class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center group-hover:bg-sky-600 transition-colors"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">
              High-Quality Workmanship
            </h3>
            <p class="text-gray-700 text-lg">
              Premium materials and expert craftsmanship guaranteed. We never
              cut corners and always use the best materials and techniques to
              ensure your pool stands the test of time.
            </p>
          </div>
        </div>

        <div
          class="flex items-start gap-6 group bg-gray-50 p-6 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="400"
        >
          <div
            class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center group-hover:bg-sky-600 transition-colors"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">
              Fast Project Turnaround
            </h3>
            <p class="text-gray-700 text-lg">
              Efficient scheduling and timely project completion. We respect
              your time and work diligently to complete projects on schedule
              without compromising quality.
            </p>
          </div>
        </div>

        <div
          class="flex items-start gap-6 group bg-gray-50 p-6 rounded-xl shadow-sm hover:shadow-md transition-all duration-300"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="500"
        >
          <div
            class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center group-hover:bg-sky-600 transition-colors"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900 mb-2">
              Affordable & Transparent Pricing
            </h3>
            <p class="text-gray-700 text-lg">
              No hidden fees, upfront quotes, and competitive rates. We believe
              in honest, transparent pricing so you know exactly what you're
              paying for before we start any work.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="w-full py-16 md:py-24 bg-gray-900 text-white">
    <div class="max-w-6xl mx-auto px-5">
      <div
        class="text-center mb-12"
        data-aos="fade-up"
        data-aos-duration="1000"
      >
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Track Record</h2>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          Numbers that speak to our experience and commitment to excellence.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div
          class="text-center"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="100"
        >
          <div class="text-4xl md:text-5xl font-extrabold text-blue-400 mb-2">
            15+
          </div>
          <div class="text-gray-300 text-lg">Years in Business</div>
        </div>
        <div
          class="text-center"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="200"
        >
          <div class="text-4xl md:text-5xl font-extrabold text-blue-400 mb-2">
            500+
          </div>
          <div class="text-gray-300 text-lg">Pools Built</div>
        </div>
        <div
          class="text-center"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="300"
        >
          <div class="text-4xl md:text-5xl font-extrabold text-blue-400 mb-2">
            1000+
          </div>
          <div class="text-gray-300 text-lg">Happy Customers</div>
        </div>
        <div
          class="text-center"
          data-aos="fade-up"
          data-aos-duration="1000"
          data-aos-delay="400"
        >
          <div class="text-4xl md:text-5xl font-extrabold text-blue-400 mb-2">
            24/7
          </div>
          <div class="text-gray-300 text-lg">Emergency Service</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="w-full py-16 md:py-20 bg-blue-700 text-white">
    <div
      class="max-w-4xl mx-auto px-5 text-center"
      data-aos="fade-up"
      data-aos-duration="1000"
    >
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Ready to Work With Us?
      </h2>
      <p class="text-xl text-blue-100 mb-8 leading-relaxed">
        Experience the Florida Pools Plus difference. Contact us today for a
        free consultation and see why Miami trusts us with their pools.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CustomLink href="/contact" children="Get in Touch" />
        <a
          href="/services"
          class="group bg-white/10 backdrop-blur-sm border-2 border-white/30 hover:bg-white/20 text-white hover:text-white text-md flex items-center gap-2 px-6 py-3 rounded transition-all duration-300 ease-out font-medium"
        >
          View Our Services
        </a>
      </div>
    </div>
  </section>
</Layout>
