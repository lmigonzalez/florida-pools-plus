---
import "swiper/css";
import "swiper/css/pagination";
---

<section class="w-full py-16 md:py-24 bg-blue-50">
  <div class="max-w-6xl mx-auto px-5">
    <!-- Section Header -->
    <div 
      class="text-center mb-12"
      data-aos="fade-up"
    >
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Why Choose Us
      </h2>
      <p class="text-xl md:text-2xl text-gray-700 font-semibold">
        Reliable. Professional. Affordable.
      </p>
    </div>

    <!-- Benefits Slider -->
    <div 
      class="swiper why-us-swiper"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div
            class="bg-white border border-blue-800 shadow-lg p-6 md:p-8 h-full flex flex-col items-center text-center gap-4 min-h-[180px]"
          >
            <div
              class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center"
            >
              <span class="text-white font-bold text-xl">✓</span>
            </div>
            <p class="text-base md:text-lg text-gray-800">
              Over 15 years of experience
            </p>
          </div>
        </div>

        <div class="swiper-slide">
          <div
            class="bg-white border border-blue-800 shadow-lg p-6 md:p-8 h-full flex flex-col items-center text-center gap-4 min-h-[180px]"
          >
            <div
              class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center"
            >
              <span class="text-white font-bold text-xl">✓</span>
            </div>
            <p class="text-base md:text-lg text-gray-800">
              Hundreds of completed projects in South Florida
            </p>
          </div>
        </div>

        <div class="swiper-slide">
          <div
            class="bg-white border border-blue-800 shadow-lg p-6 md:p-8 h-full flex flex-col items-center text-center gap-4 min-h-[180px]"
          >
            <div
              class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center"
            >
              <span class="text-white font-bold text-xl">✓</span>
            </div>
            <p class="text-base md:text-lg text-gray-800">
              High-quality materials & modern construction methods
            </p>
          </div>
        </div>

        <div class="swiper-slide">
          <div
            class="bg-white border border-blue-800 shadow-lg p-6 md:p-8 h-full flex flex-col items-center text-center gap-4 min-h-[180px]"
          >
            <div
              class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center"
            >
              <span class="text-white font-bold text-xl">✓</span>
            </div>
            <p class="text-base md:text-lg text-gray-800">
              Honest pricing and no hidden fees
            </p>
          </div>
        </div>

        <div class="swiper-slide">
          <div
            class="bg-white border border-blue-800 shadow-lg p-6 md:p-8 h-full flex flex-col items-center text-center gap-4 min-h-[180px]"
          >
            <div
              class="shrink-0 w-12 h-12 bg-blue-800 rounded-full flex items-center justify-center"
            >
              <span class="text-white font-bold text-xl">✓</span>
            </div>
            <p class="text-base md:text-lg text-gray-800">
              Fast response times and excellent customer service
            </p>
          </div>
        </div>
      </div>
      <!-- Pagination -->
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Pagination, Autoplay } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/pagination";

  document.addEventListener("DOMContentLoaded", () => {
    new Swiper(".why-us-swiper", {
      modules: [Pagination, Autoplay],
      spaceBetween: 30,
      slidesPerView: 1,
      breakpoints: {
        640: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: 3,
        },
      },
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      loop: true,
    });
  });
</script>

<style>
  .why-us-swiper {
    padding-bottom: 50px;
  }

  .why-us-swiper :global(.swiper-slide) {
    height: auto;
  }

  .why-us-swiper :global(.swiper-pagination-bullet) {
    background: #0ea5e9;
    opacity: 0.5;
  }

  .why-us-swiper :global(.swiper-pagination-bullet-active) {
    opacity: 1;
  }
</style>
