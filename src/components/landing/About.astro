---
import aboutImage from "../../assets/about.jpg";
import CustomLink from "../custom-link.astro";
---

<section class="w-full py-20 md:py-28 bg-linear-to-b from-white to-gray-50">
  <div class="max-w-7xl mx-auto px-5">
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <!-- Image -->
      <div 
        class="order-2 md:order-1 relative"
        data-aos="fade-right"
      >
        <div class="relative rounded-2xl overflow-hidden shadow-2xl">
          <img
            src={aboutImage.src}
            alt="Florida Pools Plus team"
            class="w-full h-auto object-cover"
          />
          <!-- Decorative overlay -->
          <div
            class="absolute inset-0 bg-linear-to-t from-sky-900/20 to-transparent"
          >
          </div>
        </div>
        <!-- Decorative element -->
        <div
          class="absolute -bottom-6 -right-6 w-32 h-32 bg-sky-100 rounded-full opacity-50 -z-10 hidden md:block"
        >
        </div>
      </div>

      <!-- Content -->
      <div 
        class="order-1 md:order-2"
        data-aos="fade-left"
      >
        <!-- Badge -->
        <div
          class="inline-block bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6"
        >
          About Us
        </div>

        <h2
          class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight"
        >
          Trusted Pool Experts Serving Miami for Over 15 Years
        </h2>

        <p class="text-lg md:text-xl text-gray-700 mb-8 leading-relaxed">
          Florida Pools Plus specializes in building and maintaining
          high-quality pools for residential and commercial properties. Whether
          you're looking to build a brand-new pool, completely renovate an old
          one, or keep your water crystal clear year-round, our team delivers
          exceptional results with fast, reliable service.
        </p>

        <!-- Features List -->
        <div class="space-y-5 mb-8">
          <div 
            class="flex items-start gap-4 group"
            data-aos="fade-up"
            data-aos-delay="100"
          >
            <div
              class="shrink-0 w-10 h-10 bg-blue-800 rounded-lg flex items-center justify-center group-hover:bg-sky-600 transition-colors"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <p class="text-lg font-semibold text-gray-900">
                Family-owned Miami business
              </p>
              <p class="text-gray-600 text-sm">
                Locally owned and operated since 2009
              </p>
            </div>
          </div>

          <div 
            class="flex items-start gap-4 group"
            data-aos="fade-up"
            data-aos-delay="200"
          >
            <div
              class="shrink-0 w-10 h-10 bg-blue-800 rounded-lg flex items-center justify-center group-hover:bg-sky-600 transition-colors"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-lg font-semibold text-gray-900">
                Licensed & insured contractors
              </p>
              <p class="text-gray-600 text-sm">
                Fully licensed, bonded, and insured for your protection
              </p>
            </div>
          </div>

          <div 
            class="flex items-start gap-4 group"
            data-aos="fade-up"
            data-aos-delay="300"
          >
            <div
              class="shrink-0 w-10 h-10 bg-blue-800 rounded-lg flex items-center justify-center group-hover:bg-sky-600 transition-colors"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-lg font-semibold text-gray-900">
                High-quality workmanship
              </p>
              <p class="text-gray-600 text-sm">
                Premium materials and expert craftsmanship guaranteed
              </p>
            </div>
          </div>

          <div 
            class="flex items-start gap-4 group"
            data-aos="fade-up"
            data-aos-delay="400"
          >
            <div
              class="shrink-0 w-10 h-10 bg-blue-800 rounded-lg flex items-center justify-center group-hover:bg-sky-600 transition-colors"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <p class="text-lg font-semibold text-gray-900">
                Fast project turnaround
              </p>
              <p class="text-gray-600 text-sm">
                Efficient scheduling and timely project completion
              </p>
            </div>
          </div>

          <div 
            class="flex items-start gap-4 group"
            data-aos="fade-up"
            data-aos-delay="500"
          >
            <div
              class="shrink-0 w-10 h-10 bg-blue-800 rounded-lg flex items-center justify-center group-hover:bg-sky-600 transition-colors"
            >
              <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-lg font-semibold text-gray-900">
                Affordable and transparent pricing
              </p>
              <p class="text-gray-600 text-sm">
                No hidden fees, upfront quotes, and competitive rates
              </p>
            </div>
          </div>
        </div>

        <CustomLink href="/about" children="Learn More About Us" />
      </div>
    </div>
  </div>
</section>
