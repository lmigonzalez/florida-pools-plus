---
import CustomLink from "../custom-link.astro";
---

<section class="relative w-full py-20 md:py-32 overflow-hidden">
  <!-- Gradient Background -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-sky-600 via-blue-600 to-cyan-600"
  >
  </div>

  <!-- Animated Background Pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;"
    >
    </div>
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-5 text-center">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-2 mb-6 bg-white/20 backdrop-blur-sm rounded-full border border-white/30"
      data-aos="fade-up"
    >
      <svg
        class="w-4 h-4 text-white"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5 13l4 4L19 7"></path>
      </svg>
      <span class="text-sm font-medium text-white"
        >Free Estimate • No Obligation</span
      >
    </div>

    <h2
      class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight"
      data-aos="fade-up"
      data-aos-delay="200"
    >
      Ready to Build or Renovate Your Pool?
    </h2>
    <p
      class="text-xl md:text-2xl text-blue-50 mb-10 max-w-3xl mx-auto leading-relaxed"
      data-aos="fade-up"
      data-aos-delay="300"
    >
      Get a free estimate today — fast, easy, and no obligation.
    </p>

    <div 
      class="flex flex-col sm:flex-row gap-5 justify-center items-center"
      data-aos="fade-up"
      data-aos-delay="400"
    >
      <CustomLink href="/contact" children="Request a Quote" />

      <div class="flex items-center gap-3 text-white text-lg md:text-xl">
        <div class="h-px w-8 bg-white/40"></div>
        <span class="text-blue-100">or</span>
        <div class="h-px w-8 bg-white/40"></div>
        <a
          href="tel:305-646-1625"
          class="group flex items-center gap-2 font-semibold hover:text-blue-100 transition-colors duration-300"
        >
          <svg
            class="w-5 h-5 transition-transform duration-300 group-hover:scale-110"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          <span class="underline-offset-4 hover:underline">305-646-1625</span>
        </a>
      </div>
    </div>
  </div>
</section>
