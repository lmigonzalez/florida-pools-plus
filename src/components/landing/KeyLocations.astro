---
const locations = [
  "Aventura",
  "Fort Lauderdale",
  "Boca Raton",
  "West Palm Beach",
  "North Miami Beach",
  "Weston",
  "Lighthouse Point",
  "Pompano Beach",
  "Plantation",
  "Hollywood",
  "Key Biscayne",
  "Davie",
  "Coral Springs",
  "Deerfield Beach",
  "Delray Beach",
  "Hallandale Beach",
  "Highland Beach",
  "Williams Island",
  "Pinecrest",
  "Wellington",
  "Palm Beach",
];
---

<section class="w-full py-16 md:py-24 bg-white">
  <div class="max-w-6xl mx-auto px-5">
    <!-- Section Header -->
    <div
      class="text-center mb-12"
      data-aos="fade-up"
    >
      <div
        class="inline-block bg-sky-100 text-sky-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-4"
      >
        Service Area
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Key Locations
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Proudly serving South Florida communities
      </p>
    </div>

    <!-- Locations Grid -->
    <div
      class="flex flex-wrap justify-center gap-3 md:gap-4"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      {locations.map((location, i) => (
        <span
          class="inline-flex items-center px-5 py-2.5 bg-gray-50 hover:bg-sky-50 text-gray-800 hover:text-sky-800 border border-gray-200 hover:border-sky-200 rounded-full text-sm md:text-base font-medium transition-colors duration-200"
        >
          {location}
        </span>
      ))}
    </div>
  </div>
</section>
