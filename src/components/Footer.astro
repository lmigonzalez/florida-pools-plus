---
---

<footer class="mt-auto bg-gray-900 text-white">
  <div class="max-w-6xl mx-auto px-5 py-12 md:py-16">
    <!-- Top Section -->
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-3xl font-bold mb-3 text-white">
        Florida Pools Plus
      </h2>
      <p class="text-lg md:text-xl text-gray-300 mb-2">
        Better yet, see us in person!
      </p>
      <p class="text-gray-400 mb-4">
        We love our customers, so feel free to visit during normal business
        hours.
      </p>
      <p class="text-base text-gray-500">
        Custom Designed Pools and Maintenance Services
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12 mb-12">
      <!-- Contact Information -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-sky-400 flex items-center gap-2">
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          Contact Us
        </h3>
        <div class="space-y-4 text-gray-300">
          <div class="flex items-start gap-3">
            <svg
              class="w-5 h-5 mt-1 text-sky-400 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
              ></path>
            </svg>
            <a
              href="https://maps.google.com/?q=3129+Northwest+35th+Avenue+Lauderdale+Lakes+Florida+33309"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-sky-400 transition-colors duration-300 leading-relaxed"
            >
              3129 Northwest 35th Avenue<br />
              Lauderdale Lakes, Florida 33309<br />
              United States
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg
              class="w-5 h-5 text-sky-400 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
            <a
              href="tel:9543147591"
              class="hover:text-sky-400 transition-colors duration-300"
            >
              (954) 314-7591
            </a>
          </div>
          <div class="flex items-center gap-3">
            <svg
              class="w-5 h-5 text-sky-400 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <a
              href="mailto:mypool@floridapoolsplus.com"
              class="hover:text-sky-400 transition-colors duration-300 break-all"
            >
              mypool@floridapoolsplus.com
            </a>
          </div>
        </div>
      </div>

      <!-- Business Hours -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-sky-400 flex items-center gap-2">
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          Business Hours
        </h3>
        <div class="space-y-3 text-gray-300">
          <div class="flex justify-between items-center py-1">
            <span class="font-medium">Monday - Friday</span>
            <span class="text-gray-400">9:00 AM – 5:00 PM</span>
          </div>
          <div class="flex justify-between items-center py-1">
            <span class="font-medium">Saturday</span>
            <span class="text-gray-500">Closed</span>
          </div>
          <div class="flex justify-between items-center py-1">
            <span class="font-medium">Sunday</span>
            <span class="text-gray-500">Closed</span>
          </div>
        </div>
      </div>

      <!-- Navigation Links -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-sky-400 flex items-center gap-2">
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            ></path>
          </svg>
          Quick Links
        </h3>
        <nav class="flex flex-col space-y-3">
          <a
            href="/"
            class="text-gray-300 hover:text-sky-400 transition-colors duration-300 flex items-center gap-2 group"
          >
            <span class="w-1.5 h-1.5 bg-sky-400 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Home
          </a>
          <a
            href="/services"
            class="text-gray-300 hover:text-sky-400 transition-colors duration-300 flex items-center gap-2 group"
          >
            <span class="w-1.5 h-1.5 bg-sky-400 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Services
          </a>
          <a
            href="/gallery"
            class="text-gray-300 hover:text-sky-400 transition-colors duration-300 flex items-center gap-2 group"
          >
            <span class="w-1.5 h-1.5 bg-sky-400 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Gallery
          </a>
          <a
            href="/about"
            class="text-gray-300 hover:text-sky-400 transition-colors duration-300 flex items-center gap-2 group"
          >
            <span class="w-1.5 h-1.5 bg-sky-400 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
            About
          </a>
          <a
            href="/contact"
            class="text-gray-300 hover:text-sky-400 transition-colors duration-300 flex items-center gap-2 group"
          >
            <span class="w-1.5 h-1.5 bg-sky-400 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></span>
            Contact
          </a>
        </nav>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-gray-400 text-sm">
        <p>
          © 2025 Florida Pools Plus. All rights reserved.
        </p>
        <div class="flex gap-6">
          <a
            href="/"
            class="hover:text-sky-400 transition-colors duration-300"
          >
            Privacy Policy
          </a>
          <a
            href="/"
            class="hover:text-sky-400 transition-colors duration-300"
          >
            Terms of Service
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
