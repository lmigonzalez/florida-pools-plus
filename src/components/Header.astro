---
import newPoolImg from "../assets/logo.webp";
const currentPath = Astro.url.pathname;
import { Image } from "astro:assets";
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/finance-pools", label: "Finance" },
  { href: "/gallery", label: "Gallery" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header
  class="w-full max-w-[100vw] bg-white/95 backdrop-blur-sm text-blue-800 relative z-100 border-b border-gray-100 shadow-sm uppercase"
>
  <div class="w-full mx-auto px-4 sm:px-6 lg:px-8 py-3 md:py-4 flex justify-between items-center min-w-0">
    <a
      href="/"
      class="flex items-center gap-3 z-50 shrink-0 min-w-0 transition-opacity hover:opacity-90"
    >
      <Image
        src={newPoolImg}
        alt="Florida Pools Plus"  
        class="h-32 w-auto object-contain rounded-full p-1"
      />
      <div class="hidden sm:flex flex-col normal-case pl-3 border-l border-gray-200 leading-tight">
        <span class="font-extrabold text-gray-900 text-sm md:text-base tracking-tight">
          Florida Pools Plus, Inc
        </span>
        <span class="text-gray-600 text-xs md:text-sm font-medium mt-0.5">
          Pool builders serving South Florida
        </span>
        <span class="text-[11px] md:text-xs text-blue-700 mt-1">
          New construction - renovations - weekly maintenance
        </span>
      </div>
    </a>

    <!-- Hamburger (mobile only) -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="md:hidden flex items-center justify-center w-11 h-11 rounded-xl text-blue-800 hover:bg-blue-50 focus:outline-none focus:ring-2 focus:ring-blue-800 focus:ring-offset-2 shrink-0 transition-colors cursor-pointer"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="18" x2="20" y2="18" />
      </svg>
    </button>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8 font-semibold" aria-label="Main">
      {
        navLinks.map((link) => {
          const isActive =
            currentPath === link.href ||
            (link.href !== "/" && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={`text-sm tracking-wide transition-colors ${
                isActive
                  ? "text-blue-800 font-bold relative after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-blue-800 after:rounded-full"
                  : "text-gray-700 hover:text-blue-800 relative after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:scale-x-0 after:bg-blue-800 after:rounded-full hover:after:scale-x-100 after:origin-center after:transition-transform after:duration-200"
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
      <a
        href="tel:(954) 314-7591"
        class="flex items-center gap-2 bg-blue-800 text-white text-sm font-bold px-4 py-2.5 rounded-xl hover:bg-blue-700 focus:ring-2 focus:ring-blue-800 focus:ring-offset-2 transition-colors"
      >
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V21a2 2 0 01-2 2h-1C9.716 23 3 16.284 3 8V5z" />
        </svg>
        (954) 314-7591
      </a>
    </nav>
  </div>

  <!-- Mobile menu dropdown -->
  <div
    id="mobile-menu"
    class="md:hidden hidden absolute left-0 right-0 top-full border-t border-gray-100 bg-white shadow-lg z-50"
  >
    <nav class="flex flex-col px-4 py-3" aria-label="Mobile">
      {
        navLinks.map((link) => {
          const isActive =
            currentPath === link.href ||
            (link.href !== "/" && currentPath.startsWith(link.href));
          return (
            <a
              href={link.href}
              class={`py-3.5 text-base font-semibold tracking-wide border-b border-gray-100 last:border-0 transition-colors ${
                isActive
                  ? "text-blue-800 pl-3 border-l-4 border-l-blue-800"
                  : "text-gray-700 hover:text-blue-800 pl-3"
              }`}
            >
              {link.label}
            </a>
          );
        })
      }
      <a
        href="tel:(954) 314-7591"
        class="mt-4 mb-2 flex items-center justify-center gap-2 bg-blue-800 text-white text-base font-bold px-6 py-3.5 rounded-xl hover:bg-blue-700 transition-colors normal-case"
      >
        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V21a2 2 0 01-2 2h-1C9.716 23 3 16.284 3 8V5z" />
        </svg>
        (954) 314-7591
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    btn.setAttribute("aria-expanded", String(!isOpen));
  });

  // Close when a link is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });
</script>
